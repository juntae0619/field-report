# Supabase 프로젝트 설정 (https://supabase.com/dashboard 에서 확인)
# Project Settings > API 에서 복사하세요.

# 프로젝트 URL (예: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon / publishable key (브라우저에 노출되어도 안전한 공개 키)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key (서버 전용 — 운영자 비밀번호 초기화 기능에 사용)
# 절대 NEXT_PUBLIC_ 접두사를 붙이지 마세요. 브라우저로 노출되면 안 됩니다.
SUPABASE_SERVICE_ROLE_KEY=
